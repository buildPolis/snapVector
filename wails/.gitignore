/build/*
!/build/appicon.png
!/build/darwin/
/build/darwin/*
!/build/darwin/Info.plist
!/build/darwin/Info.dev.plist
!/build/bin/
/build/bin/*
!/build/bin/snapvector.app
!/build/bin/snapvector.app/**
# Ignore macOS filesystem cruft that sneaks into the bundle
/build/bin/snapvector.app/**/.DS_Store
# Debian packages produced by scripts/package-deb.sh (shipped via Git LFS)
!/build/packages/
/build/packages/*
!/build/packages/*.deb
/vendor/
*.test
*.out
/gui/frontend/node_modules/
/gui/frontend/package.json.md5
/gui/frontend/wailsjs/
