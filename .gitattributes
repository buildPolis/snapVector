# Git LFS — track pre-built binaries shipped in-tree.
# Keeps the main Git history small while letting clones pull usable artifacts
# on demand. Run `git lfs install` after cloning, or `git lfs pull` to hydrate.

# macOS app bundle executable (Mach-O, ~8 MB per build)
wails/build/bin/**/Contents/MacOS/snapvector filter=lfs diff=lfs merge=lfs -text

# Embedded resvg rasterizer (macOS universal Mach-O, ~7 MB)
# Used by exportdoc/convert_darwin.go via go:embed to replace sips.
wails/exportdoc/bin/resvg filter=lfs diff=lfs merge=lfs -text

# Future: Windows and Linux release binaries
wails/build/bin/**/snapvector.exe filter=lfs diff=lfs merge=lfs -text
wails/build/bin/snapvector filter=lfs diff=lfs merge=lfs -text

# Packaged installers (scripts/package-*.sh emit into build/packages/)
wails/build/packages/**/*.deb filter=lfs diff=lfs merge=lfs -text
wails/build/packages/**/*.AppImage filter=lfs diff=lfs merge=lfs -text
wails/build/bin/**/*.dmg filter=lfs diff=lfs merge=lfs -text
wails/build/bin/**/*.msi filter=lfs diff=lfs merge=lfs -text
wails/build/bin/**/*-installer.exe filter=lfs diff=lfs merge=lfs -text
